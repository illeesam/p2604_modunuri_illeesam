# ══════════════════════════════════════════════════════════════════
# ShopJoy EcAdminApi - 환경변수 설정
# 경로: /volume1/docker/ec-admin-api/.env
#
# ⚠️  이 파일은 절대 Git에 커밋하지 마세요!
#     .gitignore에 반드시 등록하세요.
# ══════════════════════════════════════════════════════════════════

# ── 포트 ──────────────────────────────────
API_PORT=31000
DB_PORT=5432
REDIS_PORT=6379

# ── Database ──────────────────────────────
DB_USER=illeesam
DB_PASSWORD=postgresqlilleesam
DB_NAME=shopjoy_db

# ── Spring 프로파일 ───────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── JPA ───────────────────────────────────
# create | create-drop | validate | update | none
JPA_DDL_AUTO=validate
JPA_SHOW_SQL=false

# ── Flyway ────────────────────────────────
FLYWAY_ENABLED=true

# ── JWT ───────────────────────────────────
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters_change_this
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ── 카카오 API ─────────────────────────────
KAKAO_CLIENT_ID=your_kakao_client_id
KAKAO_CLIENT_SECRET=your_kakao_client_secret
KAKAO_REDIRECT_URI=http://illeesam.synology.me:31000/auth/kakao/callback

# ── 파일 업로드 ───────────────────────────
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=50MB
