{
    "liveServer.settings.port": 5501,
    "liveServer.settings.ignoreFiles": [
        "_apps/**",
        "_apps_be/**",
        "_doc/**",
        "log/**",
        "logs/**",
        "**/log/**",
        "**/logs/**",
        "**/*.md",
        "**/*.json",
        "**/*.py",
        "**/*.gradle",
        "**/*.kts",
        "**/*.bat",
        "**/*.java",
        "**/*.zip",
        "**/*.gz",
        "**/*.log",
        "**/*.jar",
        "**/*.bin",
        "**/*.xml",
        "**/*.properties",
        "**/*.lock",
        // 이미지 확장자 (소/대문자)
        "**/*.jpg", "**/*.JPG",
        "**/*.jpeg", "**/*.JPEG",
        "**/*.png", "**/*.PNG",
        "**/*.gif", "**/*.GIF",
        "**/*.webp", "**/*.WEBP",
        "**/*.bmp", "**/*.BMP",
        "**/*.svg", "**/*.SVG",
        "**/*.ico", "**/*.ICO",
        "**/*.tif", "**/*.tiff",
        "**/*.heic", "**/*.heif",
        "**/*.avif",
        // 동영상 확장자 (소/대문자)
        "**/*.mp4", "**/*.MP4",
        "**/*.avi", "**/*.AVI",
        "**/*.mov", "**/*.MOV",
        "**/*.mkv", "**/*.MKV",
        "**/*.webm", "**/*.WEBM",
        "**/*.flv", "**/*.FLV",
        "**/*.wmv", "**/*.WMV",
        "**/*.m4v", "**/*.M4V",
        "**/*.mpg", "**/*.mpeg",
        "**/*.3gp",
        // 엑셀·문서 확장자
        "**/*.pdf", "**/*.PDF",
        "**/*.doc", "**/*.DOC",
        "**/*.docx", "**/*.DOCX",
        "**/*.xls", "**/*.XLS",
        "**/*.xlsx", "**/*.XLSX",
        "**/*.xlsm", "**/*.XLSM",
        "**/*.xlsb",
        "**/*.csv", "**/*.CSV",
        "**/*.tsv",
        "**/*.ppt", "**/*.PPT",
        "**/*.pptx", "**/*.PPTX",
        "**/*.hwp", "**/*.HWP",
        "**/*.hwpx",
        "**/*.rtf",
        "**/*.odt", "**/*.ods", "**/*.odp",
        // 압축·기타 바이너리
        "**/*.zip", "**/*.ZIP",
        "**/*.7z", "**/*.7Z",
        "**/*.rar", "**/*.RAR",
        "**/*.tar", "**/*.tar.gz", "**/*.tgz",
        // 오디오
        "**/*.mp3", "**/*.wav", "**/*.flac", "**/*.aac", "**/*.ogg", "**/*.m4a",
        // 폰트
        "**/*.woff", "**/*.woff2", "**/*.ttf", "**/*.otf", "**/*.eot",
        "**/cdn/**",
        "**/uploads/**",
        "**/static/cdn/**",
        "**/bin/**",
        "**/bin/main/**",
        "**/node_modules/**",
        "**/.git/**",
        "**/.gradle/**",
        "**/.idea/**",
        "**/.vscode/**",
        "**/target/**",
        "**/build/**",
        "**/out/**",
        "**/dist/**"
    ],
    "java.compile.nullAnalysis.mode": "automatic",

    // ── IntelliJ ↔ VSCode 빌드 출력 충돌 방지 ──────────────────
    // VSCode Java 익스텐션이 자기만의 bin/main 을 만들면 IntelliJ/Gradle 빌드와 stale 충돌 발생
    // (FileNotFoundException: ...Repository.class cannot be opened 의 주범).
    // Gradle 위임 + 자동 빌드 OFF + IntelliJ 호환 import 로 통일.
    "java.import.gradle.enabled": true,
    "java.import.gradle.wrapper.enabled": true,
    "java.autobuild.enabled": false,                     // VSCode 자체 컴파일 비활성 (Gradle 만 사용)
    "java.configuration.maven.userSettings": null,
    "files.exclude": {
        "**/bin": true,                                   // bin/ 은 VSCode 화면에서 숨김
        "**/.idea": true,
        "**/build/classes": true,
        "**/build/generated": true
    },
    "java.import.exclusions": [
        "**/node_modules/**",
        "**/.metadata/**",
        "**/archetype-resources/**",
        "**/META-INF/maven/**",
        "**/bin/**",                                      // bin/ 은 import 대상에서 제외
        "**/out/**"
    ],

    "java.jdt.ls.java.home": "C:\\Users\\illee\\.jdks\\corretto-17.0.18",
    "java.configuration.runtimes": [
        {
            "name": "JavaSE-17",
            "path": "C:\\Users\\illee\\.jdks\\corretto-17.0.18",
            "default": true
        }
    ],
    "java.test.config": {
        "vmargs": ["-Duser.timezone=Asia/Seoul"]
    },
    "liveServer.settings.CustomBrowser": "chrome",
    "liveServer.settings.file": "bo.html",
    "liveServer.settings.root": "/",
    "liveServer.settings.useWebExt": false,
    "java.configuration.updateBuildConfiguration": "automatic"
}