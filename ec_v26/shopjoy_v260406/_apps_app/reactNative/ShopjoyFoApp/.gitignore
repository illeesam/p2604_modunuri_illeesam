yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ===== React Native =====
.expo/
.expo-shared/
web-build/
.metro-health-check*

# ===== Metro / Haste =====
.haste_cache/
.tmp/

# ===== TypeScript -----
*.tsbuildinfo

# ===== Android =====
android/.gradle/
android/build/
android/app/build/
android/.idea/
android/captures/
