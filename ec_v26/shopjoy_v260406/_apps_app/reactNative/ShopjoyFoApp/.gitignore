ios/*.xcodeproj/xcuserdata/
ios/*.xcodeproj/project.xcworkspace/xcuserdata/

# RN 번들 (release 빌드 시 자동 생성)
ios/main.jsbundle
ios/main.jsbundle.map

# Firebase 운영 키
ios/**/GoogleService-Info.plist

# Apple Developer 인증서 (절대 커밋 금지)
