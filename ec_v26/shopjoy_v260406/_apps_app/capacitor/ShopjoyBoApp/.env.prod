# ShopjoyBoApp — prod 환경 (Netlify 운영)
#
# 운영 비밀은 .env.prod.local 또는 CI 환경변수로 주입.

APP_ENV=prod
APP_NAME=ShopJoy BO
BASE_URL=https://illeesam.netlify.app/ec_v26/shopjoy_v260406/bo.html
CLEARTEXT=false
ANDROID_SCHEME=https
DEEP_LINK_SCHEME=shopjoy-bo

# 운영은 디버깅 옵션 OFF
WEB_CONTENTS_DEBUGGING=false
ALLOW_MIXED_CONTENT=false

ENABLE_BIOMETRIC=true
