# ShopjoyFoApp — local 환경
#
# 안드로이드 에뮬레이터에서 호스트 PC 의 localhost:5501 에 접근하려면 10.0.2.2 사용.
# iOS 시뮬레이터는 127.0.0.1 그대로 동작.
# 실기기 (USB) 는 PC LAN IP 사용 (예: http://192.168.0.100:5501).

APP_ENV=local
APP_NAME=ShopJoy FO Local
BASE_URL=http://10.0.2.2:5501
CLEARTEXT=true
ANDROID_SCHEME=http
DEEP_LINK_SCHEME=shopjoy-fo

# 개발용 디버깅 옵션
WEB_CONTENTS_DEBUGGING=true
ALLOW_MIXED_CONTENT=true

# 결제 (가맹점 ID — 운영 비밀이 아닌 개발용 테스트 키)
KAKAO_PAY_CID=TC0ONETIME
TOSS_CLIENT_KEY=test_ck_DnyRpQWGrN2qVqZNjp4RrKwv1M9E
