# ShopjoyFoApp — iOS Native (Swift + Xcode + XcodeGen)

# ===== XcodeGen =====
# project.yml 만 커밋, .xcodeproj / .xcworkspace 는 자동 생성하므로 무시
*.xcodeproj/
*.xcworkspace/

# ===== Xcode user-specific =====
xcuserdata/
*.xcuserstate
*.xcuserdatad/
*.mode1v3
*.mode2v3
*.perspectivev3
project.xcworkspace/

# ===== Build =====
build/
DerivedData/
*.app
*.ipa
*.dSYM.zip
*.dSYM
*.hmap
*.ipa
*.xcarchive

# ===== CocoaPods =====
Pods/
Podfile.lock          # 팀 합의에 따라 결정 (앱은 커밋 권장)
*.podspec

# ===== Swift Package Manager =====
.build/
.swiftpm/
Package.resolved      # 팀 합의에 따라 결정

# ===== Apple Developer 인증서 / 프로파일 (절대 커밋 금지) =====
*.p12
*.mobileprovision
*.cer
*.certSigningRequest
AuthKey_*.p8
ExportOptions.plist

# ===== Firebase 운영 키 (절대 커밋 금지) =====
ShopjoyFoApp/GoogleService-Info.plist
**/GoogleService-Info.plist

# ===== Fastlane =====
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output/
fastlane/Match*

# ===== OS =====
.DS_Store
Thumbs.db

# ===== IDE =====
.idea/
*.iml
.vscode/

# ===== 디버그 / 임시 =====
*.log
*.bak
*.tmp
tmp/
.netrc
