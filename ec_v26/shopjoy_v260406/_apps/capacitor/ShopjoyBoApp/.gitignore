# Apple Developer 인증서 (절대 커밋 금지)
*.mobileprovision
*.cer
AuthKey_*.p8
ExportOptions.plist

# ----- 빌드 산출물 -----
*.apk
*.aab
*.ipa
*.dSYM.zip
*.dSYM

# ----- 환경 비밀 -----
# .env.local / .env.dev / .env.prod 는 커밋 OK (URL / 공개 키만 들어감)
# 운영 비밀은 .env.{env}.local 에 두고 무시
.env
.env.*.local
.env.*.secret
secrets.json
firebase-service-account.json
# www/env.js 는 set-env.js 가 자동 생성 → 무시
www/env.js

