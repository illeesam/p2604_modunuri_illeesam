# ShopjoyFoApp — prod 환경 (Netlify 운영)
#
# 운영 배포 시에만 사용. 운영 가맹점 ID / 키는 절대 커밋 금지.
# 운영 비밀은 .env.prod.local 또는 CI 환경변수로 주입.

APP_ENV=prod
APP_NAME=ShopJoy
BASE_URL=https://illeesam.netlify.app/mainframe#sj_index
CLEARTEXT=false
ANDROID_SCHEME=https
DEEP_LINK_SCHEME=shopjoy-fo

# 운영은 디버깅 옵션 OFF
WEB_CONTENTS_DEBUGGING=false
ALLOW_MIXED_CONTENT=false

# 결제 — 운영 키는 .env.prod.local 또는 CI 시크릿으로 오버라이드
KAKAO_PAY_CID=
TOSS_CLIENT_KEY=
