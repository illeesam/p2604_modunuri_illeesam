<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.shopjoy.ecadminapi.base.ec.cm.mapper.CmBlogCateMapper">

    <!-- 게시판 카테고리 조회 조건 -->
    <sql id="cmBlogCateCond">
        <where>
            <if test="siteId != null and siteId != ''">AND c.site_id = #{siteId}</if>
            <if test="blogCateId != null and blogCateId != ''">AND c.blog_cate_id = #{blogCateId}</if>
            <if test="searchValue != null and searchValue != ''">
                AND (1=0
                    <if test="searchTypes == null or searchTypes == '' or searchTypes.contains('def_blog_cate_nm')">OR c.blog_cate_nm ILIKE '%' || #{searchValue} || '%'</if>
                )
            </if>
            <if test="dateStart != null and dateStart != '' and dateEnd != null and dateEnd != '' and dateType != null and dateType != ''">
                <choose>
                    <when test="dateType == 'reg_date'">
                        AND c.reg_date &gt;= #{dateStart}::DATE
                        AND c.reg_date &lt;  (#{dateEnd}::DATE + INTERVAL '1 day')
                    </when>
                    <when test="dateType == 'upd_date'">
                        AND c.upd_date &gt;= #{dateStart}::DATE
                        AND c.upd_date &lt;  (#{dateEnd}::DATE + INTERVAL '1 day')
                    </when>
                </choose>
            </if>
        </where>
    </sql>

    <!-- 정렬 조건 -->
    <sql id="cmBlogCateSort">
        <choose>
            <when test="sort == 'id_asc'">ORDER BY c.blog_cate_id ASC</when>
            <when test="sort == 'id_desc'">ORDER BY c.blog_cate_id DESC</when>
            <when test="sort == 'nm_asc'">ORDER BY c.blog_cate_nm ASC</when>
            <when test="sort == 'nm_desc'">ORDER BY c.blog_cate_nm DESC</when>
            <when test="sort == 'reg_asc'">ORDER BY c.reg_date ASC</when>
            <when test="sort == 'reg_desc'">ORDER BY c.reg_date DESC</when>
            <otherwise>ORDER BY c.reg_date DESC</otherwise>
        </choose>
    </sql>

    <!-- 게시판 카테고리 상세 조회 -->
    <select id="selectById" resultType="com.shopjoy.ecadminapi.base.ec.cm.data.dto.CmBlogCateDto$Item">
        SELECT  /* base.ec.cm :: CmBlogCate :: selectById */
              c.*
            , ste.site_nm AS site_nm
        FROM cm_blog_cate c
            LEFT JOIN sy_site ste ON ste.site_id = c.site_id
        WHERE c.blog_cate_id = #{id}
    </select>

    <!-- 게시판 카테고리 목록 조회 -->
    <select id="selectList" resultType="com.shopjoy.ecadminapi.base.ec.cm.data.dto.CmBlogCateDto$Item">
        SELECT  /* base.ec.cm :: CmBlogCate :: selectList */
              c.*
            , ste.site_nm AS site_nm
        FROM cm_blog_cate c
            LEFT JOIN sy_site ste ON ste.site_id = c.site_id
            <include refid="cmBlogCateCond"/>
        <include refid="cmBlogCateSort"/>
        <if test="limit != null and offset != null">LIMIT #{limit} OFFSET #{offset}</if>
    </select>

    <!-- 게시판 카테고리 페이징 목록 조회 -->
    <select id="selectPageList" resultType="com.shopjoy.ecadminapi.base.ec.cm.data.dto.CmBlogCateDto$Item">
        SELECT  /* base.ec.cm :: CmBlogCate :: selectPageList */
              c.*
            , ste.site_nm AS site_nm
        FROM cm_blog_cate c
            LEFT JOIN sy_site ste ON ste.site_id = c.site_id
            <include refid="cmBlogCateCond"/>
        <include refid="cmBlogCateSort"/>
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <!-- 게시판 카테고리 전체 건수 조회 -->
    <select id="selectPageCount" resultType="long">
        SELECT COUNT(c.*)  /* base.ec.cm :: CmBlogCate :: selectPageCount */
        FROM cm_blog_cate c
            <include refid="cmBlogCateCond"/>
    </select>

    <!-- 게시판 카테고리 선택 필드 수정 -->
    <update id="updateSelective" parameterType="com.shopjoy.ecadminapi.base.ec.cm.data.entity.CmBlogCate">
        UPDATE cm_blog_cate  /* base.ec.cm :: CmBlogCate :: updateSelective */
        <set>
            <if test="siteId != null">site_id = #{siteId},</if>
            <if test="blogCateNm != null">blog_cate_nm = #{blogCateNm},</if>
            <if test="parentBlogCateId != null">parent_blog_cate_id = #{parentBlogCateId},</if>
            <if test="sortOrd != null">sort_ord = #{sortOrd},</if>
            <if test="useYn != null">use_yn = #{useYn},</if>
            <if test="updBy != null">upd_by = #{updBy},</if>
            <if test="updDate != null">upd_date = #{updDate},</if>
        </set>
        WHERE blog_cate_id = #{blogCateId}
    </update>

</mapper>
