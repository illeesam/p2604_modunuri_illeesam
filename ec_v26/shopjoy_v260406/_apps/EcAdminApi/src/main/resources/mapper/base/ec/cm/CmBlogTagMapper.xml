<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.shopjoy.ecadminapi.base.ec.cm.mapper.CmBlogTagMapper">

    <!-- 게시물 태그 조회 조건 -->
    <sql id="cmBlogTagCond">
        <where>
            <if test="siteId != null and siteId != ''">AND t.site_id = #{siteId}</if>
            <if test="blogTagId != null and blogTagId != ''">AND t.blog_tag_id = #{blogTagId}</if>
            <if test="searchValue != null and searchValue != ''">
                AND (1=0
                    <if test="searchTypes == null or searchTypes == '' or searchTypes.contains('def_tag_nm')">OR t.tag_nm ILIKE '%' || #{searchValue} || '%'</if>
                )
            </if>
            <if test="dateStart != null and dateStart != '' and dateEnd != null and dateEnd != '' and dateType != null and dateType != ''">
                <choose>
                    <when test="dateType == 'reg_date'">
                        AND t.reg_date &gt;= #{dateStart}::DATE
                        AND t.reg_date &lt;  (#{dateEnd}::DATE + INTERVAL '1 day')
                    </when>
                    <when test="dateType == 'upd_date'">
                        AND t.upd_date &gt;= #{dateStart}::DATE
                        AND t.upd_date &lt;  (#{dateEnd}::DATE + INTERVAL '1 day')
                    </when>
                </choose>
            </if>
        </where>
    </sql>

    <!-- 정렬 조건 -->
    <sql id="cmBlogTagSort">
        <choose>
            <when test="sort == 'id_asc'">ORDER BY t.blog_tag_id ASC</when>
            <when test="sort == 'id_desc'">ORDER BY t.blog_tag_id DESC</when>
            <when test="sort == 'nm_asc'">ORDER BY t.tag_nm ASC</when>
            <when test="sort == 'nm_desc'">ORDER BY t.tag_nm DESC</when>
            <when test="sort == 'reg_asc'">ORDER BY t.reg_date ASC</when>
            <when test="sort == 'reg_desc'">ORDER BY t.reg_date DESC</when>
            <otherwise>ORDER BY t.reg_date DESC</otherwise>
        </choose>
    </sql>

    <!-- 게시물 태그 상세 조회 -->
    <select id="selectById" resultType="com.shopjoy.ecadminapi.base.ec.cm.data.dto.CmBlogTagDto$Item">
        SELECT  /* base.ec.cm :: CmBlogTag :: selectById */
              t.*
            , ste.site_nm AS site_nm
        FROM cm_blog_tag t
            LEFT JOIN sy_site ste ON ste.site_id = t.site_id
        WHERE t.blog_tag_id = #{id}
    </select>

    <!-- 게시물 태그 목록 조회 -->
    <select id="selectList" resultType="com.shopjoy.ecadminapi.base.ec.cm.data.dto.CmBlogTagDto$Item">
        SELECT  /* base.ec.cm :: CmBlogTag :: selectList */
              t.*
            , ste.site_nm AS site_nm
        FROM cm_blog_tag t
            LEFT JOIN sy_site ste ON ste.site_id = t.site_id
            <include refid="cmBlogTagCond"/>
        <include refid="cmBlogTagSort"/>
        <if test="limit != null and offset != null">LIMIT #{limit} OFFSET #{offset}</if>
    </select>

    <!-- 게시물 태그 페이징 목록 조회 -->
    <select id="selectPageList" resultType="com.shopjoy.ecadminapi.base.ec.cm.data.dto.CmBlogTagDto$Item">
        SELECT  /* base.ec.cm :: CmBlogTag :: selectPageList */
              t.*
            , ste.site_nm AS site_nm
        FROM cm_blog_tag t
            LEFT JOIN sy_site ste ON ste.site_id = t.site_id
            <include refid="cmBlogTagCond"/>
        <include refid="cmBlogTagSort"/>
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <!-- 게시물 태그 전체 건수 조회 -->
    <select id="selectPageCount" resultType="long">
        SELECT COUNT(t.*)  /* base.ec.cm :: CmBlogTag :: selectPageCount */
        FROM cm_blog_tag t
            <include refid="cmBlogTagCond"/>
    </select>

    <!-- 게시물 태그 선택 필드 수정 -->
    <update id="updateSelective" parameterType="com.shopjoy.ecadminapi.base.ec.cm.data.entity.CmBlogTag">
        UPDATE cm_blog_tag  /* base.ec.cm :: CmBlogTag :: updateSelective */
        <set>
            <if test="siteId != null">site_id = #{siteId},</if>
            <if test="blogId != null">blog_id = #{blogId},</if>
            <if test="tagNm != null">tag_nm = #{tagNm},</if>
            <if test="sortOrd != null">sort_ord = #{sortOrd},</if>
            <if test="updBy != null">upd_by = #{updBy},</if>
            <if test="updDate != null">upd_date = #{updDate},</if>
        </set>
        WHERE blog_tag_id = #{blogTagId}
    </update>

</mapper>
