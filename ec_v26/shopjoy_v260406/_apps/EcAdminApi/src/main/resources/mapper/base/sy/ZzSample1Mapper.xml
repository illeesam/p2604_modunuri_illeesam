<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.shopjoy.ecadminapi.base.sy.mapper.ZzSample1Mapper">

    <sql id="zzSample1Cond">
        <where>
            <if test="sample1Id != null and sample1Id != ''">AND s.sample1_id = #{sample1Id}</if>
            <if test="category != null and category != ''">AND s.category = #{category}</if>
            <if test="title != null and title != ''">AND s.title ILIKE '%' || #{title} || '%'</if>
            <if test="status != null and status != ''">AND s.status = #{status}</if>
            <if test="regDateStart != null and regDateStart != ''">AND s.reg_date >= #{regDateStart}::DATE</if>
            <if test="regDateEnd != null and regDateEnd != ''">AND s.reg_date &lt; (#{regDateEnd}::DATE + INTERVAL '1 day')</if>
        </where>
    </sql>

    <select id="selectById" resultType="com.shopjoy.ecadminapi.base.sy.data.dto.ZzSample1Dto$Item">
        SELECT  /* base.sy :: ZzSample1 :: selectById */
              s.*
        FROM shopjoy_2604.zz_sample1 s
        WHERE s.sample1_id = #{id}
    </select>

    <select id="selectList" resultType="com.shopjoy.ecadminapi.base.sy.data.dto.ZzSample1Dto$Item">
        SELECT  /* base.sy :: ZzSample1 :: selectList */
              s.*
        FROM shopjoy_2604.zz_sample1 s
            <include refid="zzSample1Cond"/>
        <choose>
            <when test="sort == 'id_asc'">ORDER BY s.sample1_id ASC</when>
            <when test="sort == 'id_desc'">ORDER BY s.sample1_id DESC</when>
            <when test="sort == 'title_asc'">ORDER BY s.title ASC</when>
            <when test="sort == 'title_desc'">ORDER BY s.title DESC</when>
            <when test="sort == 'reg_asc'">ORDER BY s.reg_date ASC</when>
            <when test="sort == 'reg_desc'">ORDER BY s.reg_date DESC</when>
            <otherwise>ORDER BY s.reg_date DESC</otherwise>
        </choose>
        <if test="limit != null and offset != null">LIMIT #{limit} OFFSET #{offset}</if>
    </select>

    <select id="selectPageList" resultType="com.shopjoy.ecadminapi.base.sy.data.dto.ZzSample1Dto$Item">
        SELECT  /* base.sy :: ZzSample1 :: selectPageList */
              s.*
        FROM shopjoy_2604.zz_sample1 s
            <include refid="zzSample1Cond"/>
        <choose>
            <when test="sort == 'id_asc'">ORDER BY s.sample1_id ASC</when>
            <when test="sort == 'id_desc'">ORDER BY s.sample1_id DESC</when>
            <when test="sort == 'title_asc'">ORDER BY s.title ASC</when>
            <when test="sort == 'title_desc'">ORDER BY s.title DESC</when>
            <when test="sort == 'reg_asc'">ORDER BY s.reg_date ASC</when>
            <when test="sort == 'reg_desc'">ORDER BY s.reg_date DESC</when>
            <otherwise>ORDER BY s.reg_date DESC</otherwise>
        </choose>
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="selectPageCount" resultType="long">
        SELECT COUNT(s.*)  /* base.sy :: ZzSample1 :: selectPageCount */
        FROM shopjoy_2604.zz_sample1 s
            <include refid="zzSample1Cond"/>
    </select>

    <update id="updateSelective" parameterType="com.shopjoy.ecadminapi.base.sy.data.entity.ZzSample1">
        UPDATE shopjoy_2604.zz_sample1  /* base.sy :: ZzSample1 :: updateSelective */
        <set>
            <if test="category != null">category = #{category},</if>
            <if test="title != null">title = #{title},</if>
            <if test="content != null">content = #{content},</if>
            <if test="status != null">status = #{status},</if>
            <if test="viewCount != null">view_count = #{viewCount},</if>
            <if test="updBy != null">upd_by = #{updBy},</if>
            <if test="updDate != null">upd_date = #{updDate},</if>
        </set>
        WHERE sample1_id = #{sample1Id}
    </update>

</mapper>
