<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.shopjoy.ecadminapi.base.ec.st.mapper.StErpVoucherLineMapper">

    <!-- ERP 전표 상세 조회 조건 -->
    <sql id="stErpVoucherLineCond">
        <where>
                        <if test="erpVoucherLineId != null and erpVoucherLineId != ''">AND l.erp_voucher_line_id = #{erpVoucherLineId}</if>
<if test="typeCd != null and typeCd != ''">AND l.ref_type_cd = #{typeCd}</if>
            <if test="kw != null and kw != ''">
                AND (l.account_nm ILIKE '%' || #{kw} || '%')
            </if>
            <if test="dateStart != null and dateStart != '' and dateEnd != null and dateEnd != ''">
                AND l.reg_date &gt;= #{dateStart}::DATE
                AND l.reg_date &lt;  (#{dateEnd}::DATE + INTERVAL '1 day')
            </if>
        </where>
    </sql>

    <!-- 정렬 조건 -->
    <sql id="stErpVoucherLineSort">
        <choose>
            <when test="sort == 'id_asc'">ORDER BY l.erp_voucher_line_id ASC</when>
            <when test="sort == 'id_desc'">ORDER BY l.erp_voucher_line_id DESC</when>
            <when test="sort == 'nm_asc'">ORDER BY l.account_nm ASC</when>
            <when test="sort == 'nm_desc'">ORDER BY l.account_nm DESC</when>
            <when test="sort == 'reg_asc'">ORDER BY l.reg_date ASC</when>
            <when test="sort == 'reg_desc'">ORDER BY l.reg_date DESC</when>
            <otherwise>ORDER BY l.reg_date DESC</otherwise>
        </choose>
    </sql>

    <!-- ERP 전표 상세 상세 조회 -->
    <select id="selectById" resultType="com.shopjoy.ecadminapi.base.ec.st.data.dto.StErpVoucherLineDto">
        SELECT l.*  /* base.ec.st :: StErpVoucherLine :: selectById */
        FROM st_erp_voucher_line l
        WHERE l.erp_voucher_line_id = #{id}
    </select>

    <!-- ERP 전표 상세 목록 조회 -->
    <select id="selectList" resultType="com.shopjoy.ecadminapi.base.ec.st.data.dto.StErpVoucherLineDto">
        SELECT l.*  /* base.ec.st :: StErpVoucherLine :: selectList */
        FROM st_erp_voucher_line l
            <include refid="stErpVoucherLineCond"/>
        <include refid="stErpVoucherLineSort"/>
        <if test="limit != null and offset != null">LIMIT #{limit} OFFSET #{offset}</if>
    </select>

    <!-- ERP 전표 상세 페이징 목록 조회 -->
    <select id="selectPageList" resultType="com.shopjoy.ecadminapi.base.ec.st.data.dto.StErpVoucherLineDto">
        SELECT l.*  /* base.ec.st :: StErpVoucherLine :: selectPageList */
        FROM st_erp_voucher_line l
            <include refid="stErpVoucherLineCond"/>
        <include refid="stErpVoucherLineSort"/>
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <!-- ERP 전표 상세 전체 건수 조회 -->
    <select id="selectPageCount" resultType="long">
        SELECT COUNT(l.*)  /* base.ec.st :: StErpVoucherLine :: selectPageCount */
        FROM st_erp_voucher_line l
            <include refid="stErpVoucherLineCond"/>
    </select>

    <!-- ERP 전표 상세 선택 필드 수정 -->
    <update id="updateSelective" parameterType="com.shopjoy.ecadminapi.base.ec.st.data.entity.StErpVoucherLine">
        UPDATE st_erp_voucher_line  /* base.ec.st :: StErpVoucherLine :: updateSelective */
        <set>
            <if test="erpVoucherId != null">erp_voucher_id = #{erpVoucherId},</if>
            <if test="lineNo != null">line_no = #{lineNo},</if>
            <if test="accountCd != null">account_cd = #{accountCd},</if>
            <if test="accountNm != null">account_nm = #{accountNm},</if>
            <if test="costCenterCd != null">cost_center_cd = #{costCenterCd},</if>
            <if test="profitCenterCd != null">profit_center_cd = #{profitCenterCd},</if>
            <if test="debitAmt != null">debit_amt = #{debitAmt},</if>
            <if test="creditAmt != null">credit_amt = #{creditAmt},</if>
            <if test="refTypeCd != null">ref_type_cd = #{refTypeCd},</if>
            <if test="refId != null">ref_id = #{refId},</if>
            <if test="lineMemo != null">line_memo = #{lineMemo},</if>
        </set>
        WHERE erp_voucher_line_id = #{erpVoucherLineId}
    </update>

</mapper>
