<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.shopjoy.ecadminapi.base.sy.mapper.SyAttachGrpMapper">

    <!-- 첨부파일 그룹 조회 조건 -->
    <sql id="syAttachGrpCond">
        <where>
                        <if test="attachGrpId != null and attachGrpId != ''">AND g.attach_grp_id = #{attachGrpId}</if>
<if test="kw != null and kw != ''">
                AND (g.attach_grp_nm ILIKE '%' || #{kw} || '%')
            </if>
            <if test="dateStart != null and dateStart != '' and dateEnd != null and dateEnd != ''">
                AND g.reg_date &gt;= #{dateStart}::DATE
                AND g.reg_date &lt;  (#{dateEnd}::DATE + INTERVAL '1 day')
            </if>
        </where>
    </sql>

    <!-- 정렬 조건 -->
    <sql id="syAttachGrpSort">
        <choose>
            <when test="sort == 'id_asc'">ORDER BY g.attach_grp_id ASC</when>
            <when test="sort == 'id_desc'">ORDER BY g.attach_grp_id DESC</when>
            <when test="sort == 'nm_asc'">ORDER BY g.attach_grp_nm ASC</when>
            <when test="sort == 'nm_desc'">ORDER BY g.attach_grp_nm DESC</when>
            <when test="sort == 'reg_asc'">ORDER BY g.reg_date ASC</when>
            <when test="sort == 'reg_desc'">ORDER BY g.reg_date DESC</when>
            <otherwise>ORDER BY g.reg_date DESC</otherwise>
        </choose>
    </sql>

    <!-- 첨부파일 그룹 상세 조회 -->
    <select id="selectById" resultType="com.shopjoy.ecadminapi.base.sy.data.dto.SyAttachGrpDto$Item">
        SELECT g.*  /* base.sy :: SyAttachGrp :: selectById */
        FROM sy_attach_grp g
        WHERE g.attach_grp_id = #{id}
    </select>

    <!-- 첨부파일 그룹 목록 조회 -->
    <select id="selectList" resultType="com.shopjoy.ecadminapi.base.sy.data.dto.SyAttachGrpDto$Item">
        SELECT g.*  /* base.sy :: SyAttachGrp :: selectList */
        FROM sy_attach_grp g
            <include refid="syAttachGrpCond"/>
        <include refid="syAttachGrpSort"/>
        <if test="limit != null and offset != null">LIMIT #{limit} OFFSET #{offset}</if>
    </select>

    <!-- 첨부파일 그룹 페이징 목록 조회 -->
    <select id="selectPageList" resultType="com.shopjoy.ecadminapi.base.sy.data.dto.SyAttachGrpDto$Item">
        SELECT g.*  /* base.sy :: SyAttachGrp :: selectPageList */
        FROM sy_attach_grp g
            <include refid="syAttachGrpCond"/>
        <include refid="syAttachGrpSort"/>
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <!-- 첨부파일 그룹 전체 건수 조회 -->
    <select id="selectPageCount" resultType="long">
        SELECT COUNT(g.*)  /* base.sy :: SyAttachGrp :: selectPageCount */
        FROM sy_attach_grp g
            <include refid="syAttachGrpCond"/>
    </select>

    <!-- 첨부파일 그룹 선택 필드 수정 -->
    <update id="updateSelective" parameterType="com.shopjoy.ecadminapi.base.sy.data.entity.SyAttachGrp">
        UPDATE sy_attach_grp  /* base.sy :: SyAttachGrp :: updateSelective */
        <set>
            <if test="attachGrpCode != null">attach_grp_code = #{attachGrpCode},</if>
            <if test="attachGrpNm != null">attach_grp_nm = #{attachGrpNm},</if>
            <if test="fileExtAllow != null">file_ext_allow = #{fileExtAllow},</if>
            <if test="maxFileSize != null">max_file_size = #{maxFileSize},</if>
            <if test="maxFileCount != null">max_file_count = #{maxFileCount},</if>
            <if test="storagePath != null">storage_path = #{storagePath},</if>
            <if test="useYn != null">use_yn = #{useYn},</if>
            <if test="sortOrd != null">sort_ord = #{sortOrd},</if>
            <if test="attachGrpRemark != null">attach_grp_remark = #{attachGrpRemark},</if>
            <if test="updBy != null">upd_by = #{updBy},</if>
            <if test="updDate != null">upd_date = #{updDate},</if>
        </set>
        WHERE attach_grp_id = #{attachGrpId}
    </update>

</mapper>

