<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.shopjoy.ecadminapi.base.sy.mapper.SyPathMapper">

    <sql id="cols">
        p.path_id, p.biz_cd, p.parent_path_id, p.path_label, p.sort_ord,
        p.use_yn, p.path_remark, p.reg_by, p.reg_date, p.upd_by, p.upd_date
    </sql>

    <sql id="cond">
        <where>
            <if test="p.bizCd != null and p.bizCd != ''">AND p.biz_cd = #{p.bizCd}</if>
            <if test="p.parentPathId != null">AND p.parent_path_id = #{p.parentPathId}</if>
            <if test="p.useYn != null and p.useYn != ''">AND p.use_yn = #{p.useYn}</if>
            <if test="p.kw != null and p.kw != ''">AND (p.path_label ILIKE '%'||#{p.kw}||'%' OR p.path_remark ILIKE '%'||#{p.kw}||'%')</if>
        </where>
    </sql>

    <select id="selectById" resultType="com.shopjoy.ecadminapi.base.sy.data.dto.SyPathDto">
        SELECT <include refid="cols"/>
        FROM shopjoy_2604.sy_path p
        WHERE p.path_id = #{id}
    </select>

    <select id="selectList" resultType="com.shopjoy.ecadminapi.base.sy.data.dto.SyPathDto">
        SELECT <include refid="cols"/>
        FROM shopjoy_2604.sy_path p
        <include refid="cond"/>
        ORDER BY p.sort_ord ASC, p.path_id ASC
        <if test="p.limit != null">LIMIT #{p.limit}</if>
        <if test="p.offset != null">OFFSET #{p.offset}</if>
    </select>

    <select id="selectPageList" resultType="com.shopjoy.ecadminapi.base.sy.data.dto.SyPathDto">
        SELECT <include refid="cols"/>
        FROM shopjoy_2604.sy_path p
        <include refid="cond"/>
        ORDER BY p.sort_ord ASC, p.path_id ASC
        LIMIT #{p.limit} OFFSET #{p.offset}
    </select>

    <select id="selectPageCount" resultType="long">
        SELECT COUNT(*)
        FROM shopjoy_2604.sy_path p
        <include refid="cond"/>
    </select>

    <update id="updateSelective" parameterType="com.shopjoy.ecadminapi.base.sy.data.entity.SyPath">
        UPDATE shopjoy_2604.sy_path
        <set>
            <if test="bizCd != null">biz_cd = #{bizCd},</if>
            <if test="parentPathId != null">parent_path_id = #{parentPathId},</if>
            <if test="pathLabel != null">path_label = #{pathLabel},</if>
            <if test="sortOrd != null">sort_ord = #{sortOrd},</if>
            <if test="useYn != null">use_yn = #{useYn},</if>
            <if test="pathRemark != null">path_remark = #{pathRemark},</if>
            <if test="updBy != null">upd_by = #{updBy},</if>
            <if test="updDate != null">upd_date = #{updDate},</if>
        </set>
        WHERE path_id = #{pathId}
    </update>

</mapper>
