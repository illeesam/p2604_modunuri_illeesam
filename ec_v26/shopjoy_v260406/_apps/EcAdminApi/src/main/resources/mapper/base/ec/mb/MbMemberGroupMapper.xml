<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.shopjoy.ecadminapi.base.ec.mb.mapper.MbMemberGroupMapper">

    <!-- 회원 그룹 조회 조건 -->
    <sql id="mbMemberGroupCond">
        <where>
            <if test="siteId != null and siteId != ''">AND g.site_id = #{siteId}</if>
            <if test="memberGroupId != null and memberGroupId != ''">AND g.member_group_id = #{memberGroupId}</if>
            <if test="searchValue != null and searchValue != ''">
                AND (1=0
                    <if test="searchTypes == null or searchTypes == '' or searchTypes.contains('def_group_nm')">OR g.group_nm ILIKE '%' || #{searchValue} || '%'</if>
                )
            </if>
            <if test="dateStart != null and dateStart != '' and dateEnd != null and dateEnd != '' and dateType != null and dateType != ''">
                <choose>
                    <when test="dateType == 'reg_date'">
                        AND g.reg_date &gt;= #{dateStart}::DATE
                        AND g.reg_date &lt;  (#{dateEnd}::DATE + INTERVAL '1 day')
                    </when>
                    <when test="dateType == 'upd_date'">
                        AND g.upd_date &gt;= #{dateStart}::DATE
                        AND g.upd_date &lt;  (#{dateEnd}::DATE + INTERVAL '1 day')
                    </when>
                </choose>
            </if>
        </where>
    </sql>

    <!-- 정렬 조건 -->
    <sql id="mbMemberGroupSort">
        <choose>
            <when test="sort == 'id_asc'">ORDER BY g.member_group_id ASC</when>
            <when test="sort == 'id_desc'">ORDER BY g.member_group_id DESC</when>
            <when test="sort == 'nm_asc'">ORDER BY g.group_nm ASC</when>
            <when test="sort == 'nm_desc'">ORDER BY g.group_nm DESC</when>
            <when test="sort == 'reg_asc'">ORDER BY g.reg_date ASC</when>
            <when test="sort == 'reg_desc'">ORDER BY g.reg_date DESC</when>
            <otherwise>ORDER BY g.reg_date DESC</otherwise>
        </choose>
    </sql>

    <!-- 회원 그룹 상세 조회 -->
    <select id="selectById" resultType="com.shopjoy.ecadminapi.base.ec.mb.data.dto.MbMemberGroupDto$Item">
        SELECT  /* base.ec.mb :: MbMemberGroup :: selectById */
              g.*
            , ste.site_nm AS site_nm
        FROM mb_member_group g
            LEFT JOIN sy_site ste ON ste.site_id = g.site_id
        WHERE g.member_group_id = #{id}
    </select>

    <!-- 회원 그룹 목록 조회 -->
    <select id="selectList" resultType="com.shopjoy.ecadminapi.base.ec.mb.data.dto.MbMemberGroupDto$Item">
        SELECT  /* base.ec.mb :: MbMemberGroup :: selectList */
              g.*
            , ste.site_nm AS site_nm
        FROM mb_member_group g
            LEFT JOIN sy_site ste ON ste.site_id = g.site_id
            <include refid="mbMemberGroupCond"/>
        <include refid="mbMemberGroupSort"/>
        <if test="limit != null and offset != null">LIMIT #{limit} OFFSET #{offset}</if>
    </select>

    <!-- 회원 그룹 페이징 목록 조회 -->
    <select id="selectPageList" resultType="com.shopjoy.ecadminapi.base.ec.mb.data.dto.MbMemberGroupDto$Item">
        SELECT  /* base.ec.mb :: MbMemberGroup :: selectPageList */
              g.*
            , ste.site_nm AS site_nm
        FROM mb_member_group g
            LEFT JOIN sy_site ste ON ste.site_id = g.site_id
            <include refid="mbMemberGroupCond"/>
        <include refid="mbMemberGroupSort"/>
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <!-- 회원 그룹 전체 건수 조회 -->
    <select id="selectPageCount" resultType="long">
        SELECT COUNT(g.*)  /* base.ec.mb :: MbMemberGroup :: selectPageCount */
        FROM mb_member_group g
            <include refid="mbMemberGroupCond"/>
    </select>

    <!-- 회원 그룹 선택 필드 수정 -->
    <update id="updateSelective" parameterType="com.shopjoy.ecadminapi.base.ec.mb.data.entity.MbMemberGroup">
        UPDATE mb_member_group  /* base.ec.mb :: MbMemberGroup :: updateSelective */
        <set>
            <if test="siteId != null">site_id = #{siteId},</if>
            <if test="groupNm != null">group_nm = #{groupNm},</if>
            <if test="groupMemo != null">group_memo = #{groupMemo},</if>
            <if test="useYn != null">use_yn = #{useYn},</if>
            <if test="updBy != null">upd_by = #{updBy},</if>
            <if test="updDate != null">upd_date = #{updDate},</if>
        </set>
        WHERE member_group_id = #{memberGroupId}
    </update>

</mapper>
