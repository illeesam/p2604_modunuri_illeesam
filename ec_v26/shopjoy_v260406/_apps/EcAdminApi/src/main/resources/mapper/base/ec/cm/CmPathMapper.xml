<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.shopjoy.ecadminapi.base.ec.cm.mapper.CmPathMapper">

    <!-- 경로(메뉴/URL) 조회 조건 -->
    <sql id="cmPathCond">
        <where>
            <if test="pathId != null and pathId != ''">AND p.path_id = #{pathId}</if>
            <if test="dateStart != null and dateStart != '' and dateEnd != null and dateEnd != '' and dateType != null and dateType != ''">
                <choose>
                    <when test="dateType == 'reg_date'">
                        AND p.reg_date &gt;= #{dateStart}::DATE
                        AND p.reg_date &lt;  (#{dateEnd}::DATE + INTERVAL '1 day')
                    </when>
                    <when test="dateType == 'upd_date'">
                        AND p.upd_date &gt;= #{dateStart}::DATE
                        AND p.upd_date &lt;  (#{dateEnd}::DATE + INTERVAL '1 day')
                    </when>
                </choose>
            </if>
        </where>
    </sql>

    <!-- 정렬 조건 -->
    <sql id="cmPathSort">
        <choose>
            <when test="sort == 'id_asc'">ORDER BY p.path_id ASC</when>
            <when test="sort == 'id_desc'">ORDER BY p.path_id DESC</when>
            <when test="sort == 'reg_asc'">ORDER BY p.reg_date ASC</when>
            <when test="sort == 'reg_desc'">ORDER BY p.reg_date DESC</when>
            <otherwise>ORDER BY p.reg_date DESC</otherwise>
        </choose>
    </sql>

    <!-- 경로(메뉴/URL) 상세 조회 -->
    <select id="selectById" resultType="com.shopjoy.ecadminapi.base.ec.cm.data.dto.CmPathDto$Item">
        SELECT p.*  /* base.ec.cm :: CmPath :: selectById */
        FROM cm_path p
        WHERE p.path_id = #{id}
    </select>

    <!-- 경로(메뉴/URL) 목록 조회 -->
    <select id="selectList" resultType="com.shopjoy.ecadminapi.base.ec.cm.data.dto.CmPathDto$Item">
        SELECT p.*  /* base.ec.cm :: CmPath :: selectList */
        FROM cm_path p
            <include refid="cmPathCond"/>
        <include refid="cmPathSort"/>
        <if test="limit != null and offset != null">LIMIT #{limit} OFFSET #{offset}</if>
    </select>

    <!-- 경로(메뉴/URL) 페이징 목록 조회 -->
    <select id="selectPageList" resultType="com.shopjoy.ecadminapi.base.ec.cm.data.dto.CmPathDto$Item">
        SELECT p.*  /* base.ec.cm :: CmPath :: selectPageList */
        FROM cm_path p
            <include refid="cmPathCond"/>
        <include refid="cmPathSort"/>
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <!-- 경로(메뉴/URL) 전체 건수 조회 -->
    <select id="selectPageCount" resultType="long">
        SELECT COUNT(p.*)  /* base.ec.cm :: CmPath :: selectPageCount */
        FROM cm_path p
            <include refid="cmPathCond"/>
    </select>

    <!-- 경로(메뉴/URL) 선택 필드 수정 -->
    <update id="updateSelective" parameterType="com.shopjoy.ecadminapi.base.ec.cm.data.entity.CmPath">
        UPDATE cm_path  /* base.ec.cm :: CmPath :: updateSelective */
        <set>
            <if test="bizCd != null">biz_cd = #{bizCd},</if>
            <if test="parentPathId != null">parent_path_id = #{parentPathId},</if>
            <if test="pathLabel != null">path_label = #{pathLabel},</if>
            <if test="sortOrd != null">sort_ord = #{sortOrd},</if>
            <if test="useYn != null">use_yn = #{useYn},</if>
            <if test="pathRemark != null">path_remark = #{pathRemark},</if>
            <if test="updBy != null">upd_by = #{updBy},</if>
            <if test="updDate != null">upd_date = #{updDate},</if>
        </set>
        WHERE path_id = #{pathId}
    </update>

</mapper>
