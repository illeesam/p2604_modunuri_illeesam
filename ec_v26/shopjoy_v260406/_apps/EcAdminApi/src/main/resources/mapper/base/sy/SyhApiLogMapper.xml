<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.shopjoy.ecadminapi.base.sy.mapper.SyhApiLogMapper">

    <sql id="syhApiLogCond">
        <where>
            <if test="siteId != null and siteId != ''">AND l.site_id = #{siteId}</if>
            <if test="logId != null and logId != ''">AND l.log_id = #{logId}</if>
            <if test="typeCd != null and typeCd != ''">AND l.api_type_cd = #{typeCd}</if>
            <if test="searchValue != null and searchValue != '' and searchTypes != null and searchTypes != ''">
                AND (1=0
                    <if test="searchTypes.contains('def_apiNm')">OR l.api_nm ILIKE '%' || #{searchValue} || '%'</if>
                )
            </if>
            <if test="dateStart != null and dateStart != '' and dateEnd != null and dateEnd != ''">
                AND l.reg_date &gt;= #{dateStart}::DATE
                AND l.reg_date &lt;  (#{dateEnd}::DATE + INTERVAL '1 day')
            </if>
        </where>
    </sql>

    <!-- 정렬 조건 -->
    <sql id="syhApiLogSort">
        <choose>
            <when test="sort == 'id_asc'">ORDER BY l.log_id ASC</when>
            <when test="sort == 'id_desc'">ORDER BY l.log_id DESC</when>
            <when test="sort == 'nm_asc'">ORDER BY l.api_nm ASC</when>
            <when test="sort == 'nm_desc'">ORDER BY l.api_nm DESC</when>
            <when test="sort == 'reg_asc'">ORDER BY l.reg_date ASC</when>
            <when test="sort == 'reg_desc'">ORDER BY l.reg_date DESC</when>
            <otherwise>ORDER BY l.reg_date DESC</otherwise>
        </choose>
    </sql>

    <select id="selectById" resultType="com.shopjoy.ecadminapi.base.sy.data.dto.SyhApiLogDto$Item">
        SELECT  /* base.sy :: SyhApiLog :: selectById */
              l.*
            , ste.site_nm AS site_nm
        FROM syh_api_log l
            LEFT JOIN sy_site ste ON ste.site_id = l.site_id
        WHERE l.log_id = #{id}
    </select>

    <select id="selectList" resultType="com.shopjoy.ecadminapi.base.sy.data.dto.SyhApiLogDto$Item">
        SELECT  /* base.sy :: SyhApiLog :: selectList */
              l.*
            , ste.site_nm AS site_nm
        FROM syh_api_log l
            LEFT JOIN sy_site ste ON ste.site_id = l.site_id
            <include refid="syhApiLogCond"/>
        <include refid="syhApiLogSort"/>
        <if test="limit != null and offset != null">LIMIT #{limit} OFFSET #{offset}</if>
    </select>

    <select id="selectPageList" resultType="com.shopjoy.ecadminapi.base.sy.data.dto.SyhApiLogDto$Item">
        SELECT  /* base.sy :: SyhApiLog :: selectPageList */
              l.*
            , ste.site_nm AS site_nm
        FROM syh_api_log l
            LEFT JOIN sy_site ste ON ste.site_id = l.site_id
            <include refid="syhApiLogCond"/>
        <include refid="syhApiLogSort"/>
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="selectPageCount" resultType="long">
        SELECT COUNT(l.*)  /* base.sy :: SyhApiLog :: selectPageCount */
        FROM syh_api_log l
            <include refid="syhApiLogCond"/>
    </select>

</mapper>
