<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="30 seconds">

    <!-- ================================================================
         Spring Boot 색상 변환기
         ================================================================ -->
    <conversionRule conversionWord="clr"
                    converterClass="org.springframework.boot.logging.logback.ColorConverter"/>
    <conversionRule conversionWord="wex"
                    converterClass="org.springframework.boot.logging.logback.WhitespaceThrowableProxyConverter"/>

    <!-- ================================================================
         공통 속성  (application.yml 의 logging.file.path 를 LOG_DIR 로 수신)
         ================================================================ -->
    <springProperty scope="context" name="LOG_DIR"
                    source="logging.file.path" defaultValue="logs"/>

    <property name="APP_NAME"    value="ecadminapi"/>
    <property name="APP_LOG"     value="${LOG_DIR}/${APP_NAME}.log"/>
    <property name="ERR_LOG"     value="${LOG_DIR}/${APP_NAME}-error.log"/>
    <property name="ARCH_DIR"    value="${LOG_DIR}/archived"/>

    <!-- 일반 파일 패턴 — [siteId:userTypeCd:userId:roleId] [uiNm>cmdNm] -->
    <property name="FILE_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%X{siteId}:%X{userTypeCd}:%X{userId}:%X{roleId}] [%X{uiNm}%replace(%X{cmdNm}){'(.+)', '>$1'}] [%thread] %logger{50} : %msg%n%wex"/>

    <!-- 에러 파일 패턴 — [siteId:userTypeCd:userId:roleId] + [method host/path] + [uiNm>cmdNm] -->
    <property name="ERROR_FILE_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%X{siteId}:%X{userTypeCd}:%X{userId}:%X{roleId}] [%X{req}] [%X{uiNm}%replace(%X{cmdNm}){'(.+)', '>$1'}] [%thread] %logger{50} : %msg%n%wex"/>


    <!-- ================================================================
         LOCAL / DEV
         - 콘솔: DEBUG+, 컬러, (%F:%L) IntelliJ 클릭 링크
         - 파일:  DEBUG+, 롤링(일별+50MB), 30일, 2GB, gzip 압축
         - 에러:  ERROR 전용, 롤링(일별+20MB), 90일, 500MB, gzip 압축
         ================================================================ -->
    <springProfile name="local,dev">

        <!-- 앱 시작 시 logback 내부 상태(파일 경로 포함)를 콘솔에 출력 — dev 에서는 비활성 -->
        <!-- <statusListener class="ch.qos.logback.core.status.OnConsoleStatusListener"/> -->

        <!-- ─── CONSOLE: 컬러 + (%파일:%라인) 클릭 링크 ──────────────── -->
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
                <layout class="ch.qos.logback.classic.PatternLayout">
                    <pattern>%d{HH:mm:ss.SSS} %clr(%-5level){highlight} %clr([%X{siteId}:%X{userTypeCd}:%X{userId}]){magenta} %clr([%X{uiNm}%replace(%X{cmdNm}){'(.+)', '>$1'}]){cyan} %logger{39} : %msg%n%clr(%wex){red}</pattern>
                </layout>
            </encoder>
        </appender>

        <!-- ─── MVC_LOG: AOP 메서드 추적 전용 (메시지만 출력) ──────────── -->
        <appender name="MVC_LOG_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
                <layout class="ch.qos.logback.classic.PatternLayout">
                    <pattern>%msg%n</pattern>
                </layout>
            </encoder>
        </appender>

        <!-- ─── FILE: 롤링 ──────────────────────────────────────────── -->
        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${APP_LOG}</file>
            <encoder>
                <pattern>${FILE_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <!-- 일별 롤링 + 50MB 초과 시 분할, gzip 압축 저장 -->
                <fileNamePattern>${ARCH_DIR}/${APP_NAME}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>50MB</maxFileSize>
                <maxHistory>30</maxHistory>          <!-- 30일 보관 -->
                <totalSizeCap>2GB</totalSizeCap>     <!-- 전체 최대 2 GB -->
            </rollingPolicy>
        </appender>

        <!-- ─── ERROR FILE: ERROR 전용 ───────────────────────────────── -->
        <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${ERR_LOG}</file>
            <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
                <level>ERROR</level>
            </filter>
            <encoder>
                <pattern>${ERROR_FILE_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${ARCH_DIR}/${APP_NAME}-error.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>20MB</maxFileSize>
                <maxHistory>90</maxHistory>           <!-- 에러 로그 90일 보관 -->
                <totalSizeCap>500MB</totalSizeCap>
            </rollingPolicy>
        </appender>

        <!-- ─── 비동기 래핑 (파일 I/O 논블로킹) ──────────────────────── -->
        <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
            <queueSize>512</queueSize>
            <discardingThreshold>0</discardingThreshold>  <!-- 큐 80%↑ 되어도 버리지 않음 -->
            <includeCallerData>false</includeCallerData>
            <appender-ref ref="FILE"/>
        </appender>

        <appender name="ASYNC_ERR" class="ch.qos.logback.classic.AsyncAppender">
            <queueSize>128</queueSize>
            <discardingThreshold>0</discardingThreshold>
            <includeCallerData>true</includeCallerData>   <!-- 에러: 스택 추적 완전 보존 -->
            <appender-ref ref="ERROR_FILE"/>
        </appender>

        <!-- ─── 로거 레벨 ─────────────────────────────────────────────── -->
        <!-- MVC_LOG: AOP 추적 전용 — root 전파 차단으로 이중 출력 방지 -->
        <logger name="MVC_LOG" level="INFO" additivity="false">
            <appender-ref ref="MVC_LOG_CONSOLE"/>
        </logger>

        <logger name="com.shopjoy.ecadminapi"                                level="DEBUG"/>
        <logger name="com.shopjoy.ecadminapi.config.MyBatisQueryInterceptor" level="DEBUG"/>
        <logger name="p6spy"                  level="INFO"/>
        <!-- 프레임워크 노이즈 억제 -->
        <logger name="org.springframework"    level="WARN"/>
        <logger name="org.springframework.boot.logging" level="WARN"/>
        <logger name="org.springframework.web.servlet.mvc.method.annotation" level="WARN"/>
        <logger name="org.springframework.web.servlet.handler" level="WARN"/>
        <logger name="org.hibernate"          level="WARN"/>
        <logger name="org.mybatis"            level="WARN"/>
        <logger name="org.apache.ibatis"      level="WARN"/>
        <logger name="com.zaxxer.hikari"      level="WARN"/>
        <logger name="org.apache.catalina"    level="WARN"/>
        <logger name="org.jboss.logging"      level="WARN"/>
        <logger name="io.netty"               level="WARN"/>
        <logger name="reactor"                level="WARN"/>
        <logger name="com.ulisesbocchio.jasypt" level="WARN"/>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_FILE"/>
            <appender-ref ref="ASYNC_ERR"/>
        </root>

    </springProfile>


    <!-- ================================================================
         PROD
         - 콘솔: INFO+, 간결 (색상 없음)
         - 파일:  INFO+, 롤링(일별+100MB), 30일, 3GB, gzip 압축
         - 에러:  ERROR 전용, 롤링(일별+50MB), 90일, 1GB, gzip 압축
         ================================================================ -->
    <springProfile name="prod">

        <!-- ─── CONSOLE: 심플 ───────────────────────────────────────── -->
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} : %msg%n%wex</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>

        <!-- ─── FILE: 롤링 ──────────────────────────────────────────── -->
        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${APP_LOG}</file>
            <encoder>
                <pattern>${FILE_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${ARCH_DIR}/${APP_NAME}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>100MB</maxFileSize>
                <maxHistory>30</maxHistory>
                <totalSizeCap>3GB</totalSizeCap>
            </rollingPolicy>
        </appender>

        <!-- ─── ERROR FILE ───────────────────────────────────────────── -->
        <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${ERR_LOG}</file>
            <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
                <level>ERROR</level>
            </filter>
            <encoder>
                <pattern>${ERROR_FILE_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${ARCH_DIR}/${APP_NAME}-error.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>50MB</maxFileSize>
                <maxHistory>90</maxHistory>
                <totalSizeCap>1GB</totalSizeCap>
            </rollingPolicy>
        </appender>

        <!-- ─── 비동기 래핑 ─────────────────────────────────────────── -->
        <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
            <queueSize>512</queueSize>
            <discardingThreshold>0</discardingThreshold>
            <appender-ref ref="FILE"/>
        </appender>

        <appender name="ASYNC_ERR" class="ch.qos.logback.classic.AsyncAppender">
            <queueSize>256</queueSize>
            <discardingThreshold>0</discardingThreshold>
            <includeCallerData>true</includeCallerData>
            <appender-ref ref="ERROR_FILE"/>
        </appender>

        <logger name="com.shopjoy.ecadminapi" level="INFO"/>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_FILE"/>
            <appender-ref ref="ASYNC_ERR"/>
        </root>

    </springProfile>

</configuration>
