# ═══════════════════════════════════════════════════════════
#  ShopJoy EcAdminApi - 환경변수 템플릿
# ═══════════════════════════════════════════════════════════
#  배치 위치: _apps/EcAdminApi/.env.example
#  사용 방법:
#    1. cp .env.example .env
#    2. 실제 값을 입력 (특히 비밀번호/시크릿)
#    3. .env 는 절대 Git 커밋 금지 (.gitignore 에 포함)
# ═══════════════════════════════════════════════════════════

# ───── Spring Profile ─────
# dev / staging / prod
SPRING_PROFILES_ACTIVE=dev

# ───── Database (PostgreSQL) ─────
# Synology Container Manager 단독 운영 시:
#   DB_HOST=172.17.0.1 (Docker bridge gateway)
# Docker Compose 통합 운영 시 (ecadminapi + postgres 같은 네트워크):
#   DB_HOST=postgres (서비스명)
DB_HOST=172.17.0.1
DB_PORT=17632
DB_NAME=postgres
DB_SCHEMA=shopjoy_2604
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME

# ───── JWT 시크릿 ─────
# Base64 인코딩된 16바이트 이상의 키
JWT_SECRET=CHANGE_ME

# ───── 라이선스 ─────
LICENSE_ENABLED=true
LICENSE_SECRET=CHANGE_ME

# ───── JVM 옵션 (선택) ─────
# Compose 환경에서는 docker-compose.yml 의 environment 섹션에서 설정
# JAVA_OPTS=-Xms256m -Xmx1024m
